{
  "rulesVersion": "1.3.0",
  "machine": "xBloom Studio",
  "brewMethod": "V60",
  "authoring_note": "Single source of truth for all recipes. Edit only via CALIBRATION.md rules. Every change must pass validate-recipe-table.mjs and bump rulesVersion.",
  "menus": {
    "hot": {
      "finalDrinkMl": [210, 225, 240, 255, 270],
      "finalDrinkMlByStrength": {
        "strong": [210, 224, 238, 252, 266],
        "soft": [210, 225, 240, 255, 270]
      },
      "default": 255,
      "defaultByStrength": { "strong": 252, "soft": 255 },
      "machineWaterEqualsFinal": true,
      "note": "v1.3.0: strength-based Hot Strong (1:14) and Hot Soft (1:15) for all profiles."
    },
    "cold": {
      "finalDrinkMl": [240, 270, 300, 330, 360],
      "finalDrinkMlByStrength": {
        "strong": [240, 270, 300, 330, 360],
        "soft": [240, 270, 300, 330, 360]
      },
      "default": 300,
      "defaultByStrength": { "strong": 300, "soft": 300 },
      "waterPercentBand": [55, 65],
      "iceRule": "iceG = finalDrinkMl - waterMl. Ice goes in the carafe and is NEVER entered in the xBloom app.",
      "note": "v1.3.0 strength-based cold: Strong uses ratioN 8-9 (bright) or 9 (neutral/dark); Soft uses ratioN 10 (bright/neutral) or 11 (dark)."
    }
  },
  "pourCountRule": "3 pours when waterMl < 170, otherwise 4 pours",
  "profiles": {
    "bright_clean": {
      "labelEn": "Bright & fruity",
      "labelAr": "مشرق ونظيف",
      "emoji": "☀️",
      "description": "Washed light/medium-light roasts. Citrus, floral, tea-like, berries. Needs strong hot extraction to develop sweetness that balances acidity.",
      "examples": ["Ethiopia washed", "Kenya AA", "Panama Gesha washed"]
    },
    "bright_funky": {
      "labelEn": "Funky natural",
      "labelAr": "طبيعي / تخميري",
      "emoji": "🍓",
      "description": "Naturals, anaerobics, co-ferments, infused lots. Fruit-forward and intense. Brewed COOLER than bright_clean to avoid fermented harshness.",
      "examples": ["Yemen Haraz natural", "Colombia anaerobic", "co-fermented lots"]
    },
    "neutral_classic": {
      "labelEn": "Classic balanced",
      "labelAr": "كلاسيكي متوازن",
      "emoji": "⚖️",
      "description": "Balanced washed/honey medium roasts, chocolate/caramel/nut notes, and any bean with low classification confidence. The safe default.",
      "examples": ["Colombia washed medium", "Brazil natural (chocolate/nut, medium roast)"]
    },
    "dark_roasty": {
      "labelEn": "Dark & roasty",
      "labelAr": "تحميص غامق",
      "emoji": "🍫",
      "description": "Medium-dark and dark roasts. Cool water, coarse grind, gentle handling to keep bitterness and ash out of the cup.",
      "examples": ["French roast", "Italian roast", "classic dark espresso blends brewed as filter"]
    }
  },
