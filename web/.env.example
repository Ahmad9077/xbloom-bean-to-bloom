# Public Cloudflare Worker URL (no trailing slash)
# Default: https://xbloom-recipe-worker.wld-cba.workers.dev
VITE_WORKER_URL=https://xbloom-recipe-worker.wld-cba.workers.dev

# Local Appium bridge URL (no trailing slash)
# Must be running: cd local-service && npm start
VITE_LOCAL_SERVICE_URL=http://127.0.0.1:3999

# Build-time base path for GitHub Pages deployment (set by CI, not here)
# Example: /xbloom-recipe-worker/
# VITE_BASE_PATH=/your-repo-name/
