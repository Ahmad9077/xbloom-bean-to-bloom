# xBloom Local Appium Service — non-secret configuration
# Copy to .env and adjust values. Never commit .env.

# HTTP port (bound to 127.0.0.1 only)
PORT=3999

# Appium server URL (local only)
APPIUM_URL=http://127.0.0.1:4723

# Comma-separated exact origins allowed for CORS (no wildcards)
# Leave empty to disallow all cross-origin requests.
ALLOWED_ORIGINS=https://ahmad9077.github.io,http://localhost:3000,http://127.0.0.1:3000

# Comma-separated allowed Host header values
ALLOWED_HOSTS=localhost:3999,127.0.0.1:3999

# Expected app version name and Android versionCode. Set SKIP_VERSION_CHECK=true to bypass.
EXPECTED_APP_VERSION=2.2.2
EXPECTED_APP_VERSION_CODE=2002033

# Set to true only in dev/test to skip the version check
SKIP_VERSION_CHECK=false

# Max wait for Appium element (ms)
ELEMENT_TIMEOUT_MS=10000

# Max retries for slider verification
SLIDER_MAX_RETRIES=5

# Screenshot directory (gitignored, failure captures only)
SCREENSHOT_DIR=./runtime/screenshots

# Idempotency key TTL (ms)
IDEMPOTENCY_TTL_MS=86400000

# Cloud queue used by the production website. Store BRIDGE_TOKEN in macOS
# Keychain under service "xBloom Bean to Bloom Bridge Token", account "bridge";
# run-stack.sh loads it at runtime. Do not put the token in this file.
CLOUD_WORKER_URL=https://xbloom-recipe-worker.bean-to-bloom.workers.dev
BRIDGE_POLL_INTERVAL_MS=5000
